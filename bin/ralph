#!/usr/bin/env bash
# ralph — reusable unattended "Ralph Wiggum loop" over the `pi` agent harness.
#
#   ralph <target-project-dir>
#
# Drives PLAN -> IMPLEMENT -> VALIDATE phases (each an isolated, capped pi
# session) until .ralph/BACKLOG.md drains and VALIDATE emits <goal-complete/>.
# State lives in <target>/.ralph/; safe to Ctrl-C and re-run to resume.
set -euo pipefail

# Resolve through symlinks so `ralph` works when symlinked onto PATH
# (e.g. /usr/local/bin/ralph -> repo/bin/ralph). Portable, bash 3.2-safe.
_src="${BASH_SOURCE[0]}"
while [ -h "$_src" ]; do
  _dir="$(cd -P "$(dirname "$_src")" && pwd)"
  _src="$(readlink "$_src")"
  case "$_src" in /*) ;; *) _src="$_dir/$_src" ;; esac
done
RALPH_HOME="$(cd -P "$(dirname "$_src")/.." && pwd)"
export RALPH_HOME
unset _src _dir
# shellcheck source=../lib/common.sh
source "$RALPH_HOME/lib/common.sh"
source "$RALPH_HOME/lib/state.sh"
source "$RALPH_HOME/lib/pi.sh"
source "$RALPH_HOME/lib/safety.sh"
source "$RALPH_HOME/lib/phase.sh"

usage() {
  cat <<'EOF'
Usage: ralph <target-project-dir>
       ralph reset <target-project-dir> [--keep-goal]

First run scaffolds <target>/.ralph/ and writes a GOAL.md template — fill it
in, then re-run. See docs/README.md for the env-var surface and safety model.

reset: clear harness state so the target can be used with a new goal.
       --keep-goal preserves the existing GOAL.md (useful for retrying
       the same goal after a bad run).
EOF
}

do_reset() {
  local target="$1" keep_goal="${2:-0}"
  [ -d "$target" ] || die "target is not a directory: $target"
  RALPH_TARGET="$(cd "$target" && pwd)"; export RALPH_TARGET
  local rdir="$RALPH_TARGET/.ralph"
  [ -d "$rdir" ] || die "no .ralph/ found in $target — run ralph $target first to initialise"
  rm -f "$rdir/STATE.json"
  : > "$rdir/PLAN.md"
  : > "$rdir/VALIDATION.md"
  cp "$RALPH_HOME/templates/BACKLOG.md" "$rdir/BACKLOG.md"
  rm -rf "$rdir/sessions"
  mkdir -p "$rdir/sessions"
  if [ "$keep_goal" -eq 0 ]; then
    cp "$RALPH_HOME/templates/GOAL.md" "$rdir/GOAL.md"
  fi
  journal "RESET state cleared (keep_goal=$keep_goal)"
  log "reset complete: $rdir"
}

[ $# -ge 1 ] || { usage; exit 64; }
case "$1" in -h|--help) usage; exit 0;; esac

if [ "$1" = "reset" ]; then
  [ $# -ge 2 ] || { usage; exit 64; }
  _keep_goal=0
  [ "${3:-}" = "--keep-goal" ] && _keep_goal=1
  do_reset "$2" "$_keep_goal"
  exit 0
fi

# --- preflight ---
need jq; need awk; need comm; need shasum; need sed
[ -x "$RALPH_PI_BIN" ] || command -v "$RALPH_PI_BIN" >/dev/null 2>&1 \
  || die "pi not executable at RALPH_PI_BIN=$RALPH_PI_BIN"
[ -d "$1" ] || die "target is not a directory: $1"
RALPH_TARGET="$(cd "$1" && pwd)"; export RALPH_TARGET
RDIR="$RALPH_TARGET/.ralph"

# --- bootstrap target .ralph/ ---
mkdir -p "$RDIR"/{sessions,logs}
[ -f "$RDIR/GOAL.md" ]       || cp "$RALPH_HOME/templates/GOAL.md" "$RDIR/GOAL.md"
[ -f "$RDIR/BACKLOG.md" ]    || cp "$RALPH_HOME/templates/BACKLOG.md" "$RDIR/BACKLOG.md"
[ -f "$RDIR/PLAN.md" ]       || : > "$RDIR/PLAN.md"
[ -f "$RDIR/VALIDATION.md" ] || : > "$RDIR/VALIDATION.md"
[ -f "$RDIR/JOURNAL.md" ]    || : > "$RDIR/JOURNAL.md"
# keep harness bookkeeping out of the target's own VCS
if [ -d "$RALPH_TARGET/.git" ] && ! grep -qxF '.ralph/' "$RALPH_TARGET/.gitignore" 2>/dev/null; then
  echo '.ralph/' >> "$RALPH_TARGET/.gitignore"
fi

# GOAL.md must have real (non-comment, non-blank) content
if ! grep -qvE '^\s*(<!--.*|$)' "$RDIR/GOAL.md"; then
  die "edit $RDIR/GOAL.md with your objective, then re-run."
fi

state_init

phase="$(state_get '.phase')"
case "$phase" in
  COMPLETE)    log "already COMPLETE — nothing to do (reset STATE.json to rerun)"; exit 0;;
  HALTED_*)    die "state is $phase — resolve and reset: clear $RDIR/STOP, bump RALPH_MAX_ITERATIONS, or delete $RDIR/STATE.json";;
esac

log "ralph start: target=$RALPH_TARGET resume-phase=$phase provider=${RALPH_PROVIDER:-<ambient>} plan=$RALPH_PLAN_MODEL(win=$RALPH_PLAN_CONTEXT_WINDOW) exec=$RALPH_EXEC_MODEL(win=$RALPH_EXEC_CONTEXT_WINDOW)"
journal "RUN start (resume phase=$phase, max_turns=$RALPH_MAX_TURNS, ctx_pct=$RALPH_CONTEXT_PCT, plan=$RALPH_PLAN_MODEL/$RALPH_PLAN_CONTEXT_WINDOW, exec=$RALPH_EXEC_MODEL/$RALPH_EXEC_CONTEXT_WINDOW)"

backlog_drained() { ! grep -qE '^[[:space:]]*- \[ \]' "$RDIR/BACKLOG.md"; }

# --- outer state machine ---
while true; do
  safety_check_stop
  iter="$(state_get '.iteration')"
  iter=$((iter + 1))
  safety_check_maxiter "$iter"
  state_update ".iteration=$iter"
  phase="$(state_get '.phase')"

  case "$phase" in
    PLAN)
      run_phase plan
      next="IMPLEMENT"
      ;;
    IMPLEMENT)
      run_phase implement
      next="VALIDATE"
      ;;
    VALIDATE)
      run_phase validate
      safety_check_stuck   # halts on 3 identical consecutive VALIDATION.md
      if [ "${RALPH_SAW_GOAL_DONE:-0}" -eq 1 ] && backlog_drained; then
        state_update '.goal_complete=true | .phase="COMPLETE"'
        journal "COMPLETE iter=$iter (backlog drained + <goal-complete/> verified)"
        log "GOAL COMPLETE after $iter iterations"
        exit 0
      fi
      if backlog_drained; then
        next="PLAN"      # goal unmet but backlog empty -> re-plan
        log "backlog drained, goal unmet -> re-PLAN"
      else
        next="IMPLEMENT"  # more items remain
      fi
      ;;
    *) die "unexpected phase in loop: $phase";;
  esac

  state_update ".phase=\"$next\""
  journal "iter=$iter $phase -> $next (exit=${RALPH_PHASE_EXIT:-?}, turns=$(state_get '.last_turns_used'), ctx=$(state_get '.last_ctx_fraction'))"
done
